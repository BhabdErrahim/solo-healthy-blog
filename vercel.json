{
  "version": 2,
  "builds": [
    {
      "src": "core/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/token",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/api/token/",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/api/token/refresh",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/api/token/refresh/",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/sys-admin/(.*)",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/sitemap.xml",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/static/admin/(.*)",
      "dest": "core/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ]
}